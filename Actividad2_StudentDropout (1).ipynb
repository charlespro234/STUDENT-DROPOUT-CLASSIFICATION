    "# CELL 2 - Generate synthetic dataset (from Activity I)\n",
    "def generate_synthetic_dataset(n=600, seed=42):\n",
    "    np.random.seed(seed)\n",
    "    age           = np.random.randint(16, 30, n).astype(float)\n",
    "    gender        = np.random.choice(['Male','Female','Other'], n, p=[.48,.48,.04])\n",
    "    city          = np.random.choice(['Barranquilla','Bogota','Medellin','Cartagena','Other'], n, p=[.40,.20,.15,.15,.10])\n",
    "    hs_gpa        = np.random.normal(3.4, 0.6, n).clip(0, 5)\n",
    "    admission_score = np.random.normal(55, 12, n).clip(10, 100)\n",
    "    sem1_gpa      = np.random.normal(3.2, 0.7, n).clip(0, 5)\n",
    "    socioeconomic = np.random.choice(['Level 1','Level 2','Level 3','Level 4','Level 5'], n, p=[.20,.30,.25,.15,.10])\n",
    "    scholarship   = np.random.choice(['Yes','No'], n, p=[.35,.65])\n",
    "    loan          = np.random.choice(['Yes','No'], n, p=[.40,.60])\n",
    "    financial_aid = np.random.choice(['None','Partial','Full'], n, p=[.45,.35,.20])\n",
    "\n",
    "    risk = (\n",
    "        (sem1_gpa < 3.0).astype(int) * 2 +\n",
    "        (hs_gpa < 3.0).astype(int) +\n",
    "        (socioeconomic == 'Level 1').astype(int) +\n",
    "        (socioeconomic == 'Level 2').astype(int) +\n",
    "        (scholarship == 'No').astype(int) +\n",
    "        (financial_aid == 'None').astype(int) +\n",
    "        (admission_score < 45).astype(int)\n",
    "    )\n",
    "    prob    = 1 / (1 + np.exp(-(risk - 3)))\n",
    "    dropout = np.where(np.random.rand(n) < prob, 'Yes', 'No')\n",
    "\n",
    "    df = pd.DataFrame({\n",
    "        'age': age, 'gender': gender, 'city_of_origin': city,\n",
    "        'hs_gpa': hs_gpa.round(2),\n",
    "        'admission_score': admission_score.round(1),\n",
    "        'sem1_gpa': sem1_gpa.round(2),\n",
    "        'socioeconomic_level': socioeconomic,\n",
    "        'scholarship': scholarship, 'loan': loan,\n",
    "        'financial_aid': financial_aid, 'dropout': dropout\n",
    "    })\n",
    "\n",
    "    # Introduce null values (~8% per numeric column)\n",
    "    for col in ['age','hs_gpa','admission_score','sem1_gpa']:\n",
    "        df.loc[np.random.choice(df.index, int(n*.08), replace=False), col] = np.nan\n",
    "\n",
    "    # Introduce outliers (~3%)\n",
    "    nb_out = int(n*.015)\n",
    "    df.loc[np.random.choice(df.index, nb_out, replace=False), 'sem1_gpa']        = np.random.uniform(0, .5, nb_out)\n",
    "    df.loc[np.random.choice(df.index, nb_out, replace=False), 'admission_score'] = np.random.uniform(95, 120, nb_out)\n",
    "    return df\n",
    "\n",
    "df_syn = generate_synthetic_dataset()\n",
    "print(f\"Synthetic dataset shape: {df_syn.shape}\")\n",
    "print(df_syn['dropout'].value_counts())\n",
    "df_syn.head()\n"
   ]
  },
