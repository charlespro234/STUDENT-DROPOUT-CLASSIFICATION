    "# CELL 4 - Main function: 10 steps of the activity\n",
    "def run_pipeline(df_input, dataset_name=\"Synthetic\"):\n",
    "    print(f\"\\n{'='*60}\")\n",
    "    print(f\"  DATASET: {dataset_name}\")\n",
    "    print(f\"{'='*60}\")\n",
    "\n",
    "    df = df_input.copy()\n",
    "    target_col = 'dropout'\n",
    "\n",
    "    # -------------------------------------------------------\n",
    "    # STEP 1: Data Cleaning\n",
    "    # -------------------------------------------------------\n",
    "    print(\"\\n[STEP 1] DATA CLEANING\")\n",
    "    print(f\"  Initial shape : {df.shape}\")\n",
    "    print(f\"  Duplicates    : {df.duplicated().sum()}\")\n",
    "    df.drop_duplicates(inplace=True)\n",
    "    print(f\"  Final shape   : {df.shape}\")\n",
    "    print(f\"  Total nulls   : {df.isnull().sum().sum()}\")\n",
    "    print(\"  Target distribution:\")\n",
    "    print(df[target_col].value_counts())\n",
    "\n",
    "    # -------------------------------------------------------\n",
    "    # STEP 2: Exploratory Data Analysis (EDA)\n",
    "    # -------------------------------------------------------\n",
    "    print(\"\\n[STEP 2] EXPLORATORY DATA ANALYSIS (EDA)\")\n",
    "    num_cols = df.select_dtypes(include='number').columns.tolist()\n",
    "    cat_cols = df.select_dtypes(include='object').columns.difference([target_col]).tolist()\n",
    "\n",
    "    print(f\"  Numeric columns    : {len(num_cols)}\")\n",
    "    print(f\"  Categorical columns: {len(cat_cols)}\")\n",
    "\n",
    "    print(\"\\nDescriptive statistics (numeric variables):\")\n",
    "    display(df[num_cols].describe().round(2))\n",
    "\n",
    "    print(\"\\nFrequency tables (categorical variables):\")\n",
    "    for c in cat_cols[:4]:\n",
    "        print(f\"  {c}:\")\n",
    "        print(df[c].value_counts(), \"\\n\")\n",
    "\n",
    "    # EDA plots\n",
    "    fig, axes = plt.subplots(1, 3, figsize=(16, 4))\n",
    "    fig.suptitle(f'EDA - {dataset_name}', fontsize=13, fontweight='bold')\n",
    "\n",
    "    # Class balance\n",
    "    df[target_col].value_counts().plot(kind='bar', ax=axes[0],\n",
    "        color=['#2ecc71','#e74c3c'], edgecolor='black')\n",
    "    axes[0].set_title('Class Balance')\n",
    "    axes[0].set_xlabel('Dropout')\n",
    "    axes[0].tick_params(axis='x', rotation=0)\n",
    "\n",
    "    # Distribution of first numeric variable\n",
    "    if num_cols:\n",
    "        df[num_cols[0]].dropna().hist(bins=30, ax=axes[1], color='#3498db', edgecolor='black')\n",
    "        axes[1].set_title(f'Distribution: {num_cols[0]}')\n",
    "\n",
    "    # Boxplot: second numeric variable vs target\n",
    "    if len(num_cols) > 1:\n",
    "        df.boxplot(column=num_cols[1], by=target_col, ax=axes[2])\n",
    "        plt.sca(axes[2])\n",
    "        plt.title(f'{num_cols[1]} vs Dropout')\n",
    "\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "    # -------------------------------------------------------\n",
    "    # STEP 3: Correlation Map\n",
    "    # -------------------------------------------------------\n",
    "    print(\"\\n[STEP 3] CORRELATION MAP\")\n",
    "    df_corr = df[num_cols].copy()\n",
    "    df_corr['dropout_bin'] = (df[target_col] == 'Yes').astype(int)\n",
    "    corr_matrix = df_corr.corr()\n",
    "\n",
    "    plt.figure(figsize=(min(14, len(df_corr.columns)+2), min(12, len(df_corr.columns)+2)))\n",
    "    mask = np.triu(np.ones_like(corr_matrix, dtype=bool))\n",
    "    sns.heatmap(corr_matrix, mask=mask, annot=True, fmt='.2f',\n",
    "                cmap='coolwarm', center=0, linewidths=.5, annot_kws={'size': 7})\n",
    "    plt.title(f'Correlation Map - {dataset_name}')\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "    corr_target = corr_matrix['dropout_bin'].drop('dropout_bin').abs().sort_values(ascending=False)\n",
    "    print(\"  Strongest correlations with dropout:\")\n",
    "    print(corr_target.head(3).to_string())\n",
    "    print(\"\\n  Weakest correlations with dropout:\")\n",
    "    print(corr_target.tail(3).to_string())\n",
    "\n",
    "    # -------------------------------------------------------\n",
    "    # STEP 4: Preprocessing and Pipelines\n",
    "    # -------------------------------------------------------\n",
    "    print(\"\\n[STEP 4] PREPROCESSING - ColumnTransformer with Pipelines\")\n",
    "    X = df.drop(columns=[target_col])\n",
    "    y = (df[target_col] == 'Yes').astype(int)\n",
    "\n",
    "    num_features = X.select_dtypes(include='number').columns.tolist()\n",
    "    cat_features = X.select_dtypes(include='object').columns.tolist()\n",
    "    print(f\"  Numeric features    ({len(num_features)}): {num_features[:5]}{'...' if len(num_features)>5 else ''}\")\n",
    "    print(f\"  Categorical features({len(cat_features)}): {cat_features[:5]}{'...' if len(cat_features)>5 else ''}\")\n",
    "\n",
    "    # Numeric pipeline: imputation (median) + StandardScaler\n",
    "    numeric_pipeline = Pipeline([\n",
    "        ('imputer', SimpleImputer(strategy='median')),\n",
    "        ('scaler',  StandardScaler())\n",
    "    ])\n",
    "    # Categorical pipeline: imputation (most_frequent) + OneHotEncoder\n",
    "    categorical_pipeline = Pipeline([\n",
    "        ('imputer', SimpleImputer(strategy='most_frequent')),\n",
    "        ('encoder', OneHotEncoder(handle_unknown='ignore', sparse_output=False))\n",
    "    ])\n",
    "    preprocessor = ColumnTransformer([\n",
    "        ('num', numeric_pipeline,     num_features),\n",
    "        ('cat', categorical_pipeline, cat_features)\n",
    "    ])\n",
    "    print(\"  Numeric  : SimpleImputer(median) + StandardScaler\")\n",
    "    print(\"  Categorical: SimpleImputer(most_frequent) + OneHotEncoder(handle_unknown=ignore)\")\n",
    "\n",
    "    # -------------------------------------------------------\n",
    "    # STEP 5: Train-Test Split\n",
    "    # -------------------------------------------------------\n",
    "    print(\"\\n[STEP 5] TRAIN-TEST SPLIT (80% / 20%)\")\n",
    "    X_train, X_test, y_train, y_test = train_test_split(\n",
    "        X, y, test_size=0.20, random_state=42, stratify=y)\n",
    "    print(f\"  Training set : {X_train.shape[0]} records\")\n",
    "    print(f\"  Test set     : {X_test.shape[0]} records\")\n",
    "    print(f\"  Train balance -> No: {(y_train==0).sum()} | Yes: {(y_train==1).sum()}\")\n",
    "\n",
    "    # -------------------------------------------------------\n",
    "    # STEP 6: Models\n",
    "    # -------------------------------------------------------\n",
    "    print(\"\\n[STEP 6] MODEL DEFINITION\")\n",
    "    pipe_lr = Pipeline([\n",
    "        ('prep',  preprocessor),\n",
    "        ('model', LogisticRegression(max_iter=1000, class_weight='balanced', random_state=42))\n",
    "    ])\n",
    "    pipe_dt = Pipeline([\n",
    "        ('prep',  preprocessor),\n",
    "        ('model', DecisionTreeClassifier(max_depth=6, class_weight='balanced', random_state=42))\n",
    "    ])\n",
    "    print(\"  Model 1: Logistic Regression (max_iter=1000, class_weight=balanced)\")\n",
    "    print(\"  Model 2: Decision Tree       (max_depth=6,   class_weight=balanced)\")\n",
    "\n",
    "    # -------------------------------------------------------\n",
    "    # STEP 7: 5-Fold Cross-Validation\n",
    "    # -------------------------------------------------------\n",
    "    print(\"\\n[STEP 7] 5-FOLD CROSS-VALIDATION (scoring=f1)\")\n",
    "    cv = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)\n",
    "    cv_lr = cross_val_score(pipe_lr, X_train, y_train, cv=cv, scoring='f1')\n",
    "    cv_dt = cross_val_score(pipe_dt, X_train, y_train, cv=cv, scoring='f1')\n",
    "    print(f\"  Logistic Regression -> F1 per fold: {cv_lr.round(3)} | Mean: {cv_lr.mean():.4f} +/- {cv_lr.std():.4f}\")\n",
    "    print(f\"  Decision Tree       -> F1 per fold: {cv_dt.round(3)} | Mean: {cv_dt.mean():.4f} +/- {cv_dt.std():.4f}\")\n",
    "\n",
    "    # -------------------------------------------------------\n",
    "    # STEP 8: Metrics on Test Set\n",
    "    # -------------------------------------------------------\n",
    "    print(\"\\n[STEP 8] METRICS ON TEST SET\")\n",
    "    pipe_lr.fit(X_train, y_train)\n",
    "    pipe_dt.fit(X_train, y_train)\n",
    "\n",
    "    results = {}\n",
    "    for name, pipe in [('Logistic Regression', pipe_lr), ('Decision Tree', pipe_dt)]:\n",
    "        y_pred  = pipe.predict(X_test)\n",
    "        y_proba = pipe.predict_proba(X_test)[:, 1]\n",
    "        results[name] = {\n",
    "            'y_pred': y_pred, 'y_proba': y_proba,\n",
    "            'acc' : accuracy_score(y_test, y_pred),\n",
    "            'prec': precision_score(y_test, y_pred, zero_division=0),\n",
    "            'rec' : recall_score(y_test, y_pred, zero_division=0),\n",
    "            'f1'  : f1_score(y_test, y_pred, zero_division=0),\n",
    "            'auc' : roc_auc_score(y_test, y_proba)\n",
    "        }\n",
    "        print(f\"\\n  -- {name} --\")\n",
    "        print(f\"  Accuracy={results[name]['acc']:.4f} | Precision={results[name]['prec']:.4f} | Recall={results[name]['rec']:.4f} | F1={results[name]['f1']:.4f} | AUC={results[name]['auc']:.4f}\")\n",
    "        print(classification_report(y_test, y_pred, target_names=['No dropout','Dropout']))\n",
    "\n",
    "    # Evaluation plots\n",
    "    fig, axes = plt.subplots(2, 3, figsize=(17, 10))\n",
    "    fig.suptitle(f'Model Evaluation - {dataset_name}', fontsize=13, fontweight='bold')\n",
    "    colors = {'Logistic Regression': '#3498db', 'Decision Tree': '#e74c3c'}\n",
    "\n",
    "    for i, (name, res) in enumerate(results.items()):\n",
    "        # Confusion matrix\n",
    "        cm = confusion_matrix(y_test, res['y_pred'])\n",
    "        ConfusionMatrixDisplay(cm, display_labels=['No dropout','Dropout']).plot(\n",
    "            ax=axes[i,0], colorbar=False, cmap='Blues')\n",
    "        axes[i,0].set_title(f'Confusion Matrix - {name}')\n",
    "\n",
    "        # ROC curve\n",
    "        fpr, tpr, _ = roc_curve(y_test, res['y_proba'])\n",
    "        axes[i,1].plot(fpr, tpr, color=colors[name], lw=2, label=f'AUC={res[\"auc\"]:.3f}')\n",
    "        axes[i,1].plot([0,1],[0,1],'k--',lw=1)\n",
    "        axes[i,1].set_xlabel('False Positive Rate')\n",
    "        axes[i,1].set_ylabel('True Positive Rate')\n",
    "        axes[i,1].set_title(f'ROC Curve - {name}')\n",
    "        axes[i,1].legend(loc='lower right')\n",
    "        axes[i,1].grid(alpha=.3)\n",
    "\n",
    "    # Metrics comparison bar chart\n",
    "    metric_keys   = ['acc','prec','rec','f1','auc']\n",
    "    metric_labels = ['Accuracy','Precision','Recall','F1','AUC']\n",
    "    x = np.arange(len(metric_labels)); w = 0.35\n",
    "    axes[0,2].bar(x-w/2, [results['Logistic Regression'][m] for m in metric_keys], w,\n",
    "                  label='Logistic Reg.', color='#3498db', edgecolor='black')\n",
    "    axes[0,2].bar(x+w/2, [results['Decision Tree'][m] for m in metric_keys], w,\n",
    "                  label='Decision Tree', color='#e74c3c', edgecolor='black')\n",
    "    axes[0,2].set_xticks(x)\n",
    "    axes[0,2].set_xticklabels(metric_labels)\n",
    "    axes[0,2].set_ylim(0, 1.1)\n",
    "    axes[0,2].set_title('Metrics Comparison')\n",
    "    axes[0,2].legend()\n",
    "    axes[0,2].grid(axis='y', alpha=.3)\n",
    "\n",
    "    # Cross-validation F1 boxplot\n",
    "    axes[1,2].boxplot([cv_lr, cv_dt], labels=['Logistic Reg.','Decision Tree'],\n",
    "                      patch_artist=True, boxprops=dict(facecolor='lightblue'))\n",
    "    axes[1,2].set_title('F1 Cross-Validation (5-fold)')\n",
    "    axes[1,2].set_ylabel('F1-Score')\n",
    "    axes[1,2].grid(axis='y', alpha=.3)\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "    # -------------------------------------------------------\n",
    "    # STEP 9: Model Selection\n",
    "    # -------------------------------------------------------\n",
    "    print(\"\\n[STEP 9] MODEL SELECTION\")\n",
    "    best_model = max(results, key=lambda k: results[k]['f1'])\n",
    "    print(f\"  Best model: {best_model}\")\n",
    "    print(f\"  F1 Logistic Regression : {results['Logistic Regression']['f1']:.4f}\")\n",
    "    print(f\"  F1 Decision Tree       : {results['Decision Tree']['f1']:.4f}\")\n",
    "    print(f\"  Selection criterion    : highest F1-Score on test set\")\n",
    "\n",
    "    # Decision tree visualization (first 3 levels)\n",
    "    try:\n",
    "        fn_cat = (pipe_dt.named_steps['prep']\n",
    "                  .transformers_[1][1]\n",
    "                  .named_steps['encoder']\n",
    "                  .get_feature_names_out(cat_features).tolist())\n",
    "        feature_names = num_features + fn_cat\n",
    "    except Exception:\n",
    "        feature_names = None\n",
    "\n",
    "    fig, ax = plt.subplots(figsize=(18, 6))\n",
    "    plot_tree(pipe_dt.named_steps['model'], max_depth=3,\n",
    "              feature_names=feature_names, class_names=['No','Yes'],\n",
    "              filled=True, rounded=True, fontsize=8, ax=ax)\n",
    "    ax.set_title(f'Decision Tree (first 3 levels) - {dataset_name}')\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "    # -------------------------------------------------------\n",
    "    # STEP 10: Conclusions\n",
    "    # -------------------------------------------------------\n",
    "    print(\"\\n[STEP 10] CONCLUSIONS\")\n",
    "    lr = results['Logistic Regression']\n",
    "    dt = results['Decision Tree']\n",
    "    print(f\"\"\"\n",
    "  Dataset: {dataset_name}\n",
    "\n",
    "  Logistic Regression\n",
    "    Accuracy={lr['acc']:.3f} | Precision={lr['prec']:.3f} | Recall={lr['rec']:.3f} | F1={lr['f1']:.3f} | AUC={lr['auc']:.3f}\n",
    "    Strength  : Simple, fast, and interpretable through its coefficients.\n",
    "    Limitation: Assumes a linear relationship between features and log-odds.\n",
    "\n",
    "  Decision Tree\n",
    "    Accuracy={dt['acc']:.3f} | Precision={dt['prec']:.3f} | Recall={dt['rec']:.3f} | F1={dt['f1']:.3f} | AUC={dt['auc']:.3f}\n",
    "    Strength  : Captures non-linear relationships; visualizable as decision rules.\n",
    "    Limitation: Prone to overfitting without depth control.\n",
    "\n",
    "  Recommended model: {best_model}\n",
    "    Selected based on the highest F1-Score, which balances Precision and Recall.\n",
    "    This is essential for an early-warning dropout system where both false alarms\n",
    "    and undetected at-risk students carry a real institutional cost.\n",
    "    \"\"\")\n",
    "    return results\n"
   ]
